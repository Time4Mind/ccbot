# --- Required ---

# Telegram Bot Token
TELEGRAM_BOT_TOKEN=your_bot_token_here

# Allowed user IDs (comma-separated). DM mode expects a single id.
ALLOWED_USERS=123456789

# --- Tmux / Claude ---

# Tmux session name
TMUX_SESSION_NAME=ccbot

# Claude command and flags. Bypass-mode is the default in DM mode.
CLAUDE_COMMAND=claude
CLAUDE_FLAGS=--dangerously-skip-permissions
IS_SANDBOX=1

# Monitor polling interval in seconds
MONITOR_POLL_INTERVAL=2.0

# Custom claude projects path (rarely needed)
# CCBOT_CLAUDE_PROJECTS_PATH=

# --- Sessions / Archive ---

# Soft cap, warning only
MAX_SESSIONS=10

# Idle threshold before auto-archive (e.g. 4h, 90m, 7200s)
SESSION_IDLE_TTL=4h

# Hard purge of archived state records (transcripts on disk are kept)
ARCHIVE_PURGE_AFTER=14d

# Per-session 5h soft warning threshold (tokens)
SESSION_TOKEN_BUDGET_5H=15000

# --- Budgets (calibrated empirically for Max x20) ---

MAX_5H_TOKENS=50000
MAX_WEEKLY_TOKENS=640000

# --- A8 switcher / preview ---

PREVIEW_USER_LINES=4
PREVIEW_ASSISTANT_LINES=8
PREVIEW_TOOLS=2
# Coalescing window for live preview updates; 0 disables live updates.
PREVIEW_LIVE_LAG=4

# --- Notifications ---

# separate | footer
BG_NOTIFY_MODE=separate

# --- Voice ---

# auto | whisper | apple | off
VOICE_BACKEND=auto
# WHISPER_MODEL_PATH=/var/lib/ccbot/models/ggml-medium.bin
# WHISPER_BIN=whisper-cli

# --- Media inbox ---

INBOX_TTL_HOURS=24

# --- Display ---

CCBOT_SHOW_USER_MESSAGES=true
CCBOT_SHOW_TOOL_CALLS=true
CCBOT_SHOW_HIDDEN_DIRS=false

# --- Identity (surfaced to Claude inside each session) ---
# CCBOT_HOST and CCBOT_BOT_USERNAME are exported into each session's
# Claude process so it can tell which device + which bot it's running
# under (handy when one user runs multiple ccbot deployments).
# CCBOT_HOST defaults to `socket.gethostname()`; override when the
# hostname is opaque (e.g. `localhost.localdomain`).
# CCBOT_BOT_USERNAME is auto-filled at startup via getMe — do not set.
# CCBOT_HOST=my-deployment
